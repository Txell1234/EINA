## 7. PATRONS DE CODI — EXEMPLES REALS DEL REPO

### Router FastAPI (veure backend/routers/geopolitical.py per referència)
```python
from fastapi import APIRouter, Depends
from sqlalchemy.ext.asyncio import AsyncSession
from app.database import get_db

router = APIRouter()

@router.post("/endpoint")
async def endpoint(data: SchemaModel, db: AsyncSession = Depends(get_db)):
    svc = MyService(db)
    result = await svc.do_something(data)
    return result
```

### Component React (veure frontend/src/components/Geopolitical/RiskDashboard.tsx per referència)
```tsx
import { useState } from 'react'
import { useQuery } from '@tanstack/react-query'
import { prospectiveService } from '../../services/api'
import './ProspectiveAnalysis.css'

interface Props {
  caseId?: number
}

export default function ProspectiveAnalysis({ caseId }: Props) {
  const [step, setStep] = useState(0)

  const { data: projects, isLoading } = useQuery({
    queryKey: ['prospective-projects', caseId],
    queryFn: () => prospectiveService.listProjects(caseId),
  })

  if (isLoading) return <div className="spinner" />

  return (
    <div className="prospective-container">
      {/* wizard */}
    </div>
  )
}
```

