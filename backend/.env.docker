# Còpia d'aquest fitxer a backend/.env i edita els valors
# Per a Docker: docker compose up --build

DEBUG=False
HOST=0.0.0.0
PORT=8000

# Base de dades (Docker usa volum persistent)
DATABASE_URL=sqlite+aiosqlite:////app/data/eina.db

# OBLIGATORI: genera amb python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CANVIA_AQUEST_VALOR_AMB_LA_COMANDA_DE_DALT

# LLM — afegeix almenys UNA clau
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Models (no cal canviar-los)
ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SCENARIO_MODEL=claude-sonnet-4-20250514
OPENAI_EXTRACT_MODEL=gpt-4o-mini
OPENAI_SCENARIO_MODEL=gpt-4o

# Opcional
NEWS_API_KEY=
GITHUB_TOKEN=
