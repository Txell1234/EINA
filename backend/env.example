# Application
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./osint_platform.db
# Producció PostgreSQL: postgresql+asyncpg://user:pass@host:5432/eina
USE_ALEMBIC=false

# Security
# OBLIGATORI - genera amb: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERA_UNA_CLAU_ALEATORIA_AMB_LA_COMANDA_DE_DALT
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Proveïdor LLM per extracció OSINT, escenaris prospectius i anàlisi directa
# Configura NOMÉS una clau (o diverses) i tria el proveïdor actiu:
#   LLM_PROVIDER=openai   → només OPENAI_API_KEY
#   LLM_PROVIDER=gemini   → només GEMINI_API_KEY
#   LLM_PROVIDER=auto   → primera clau disponible (anthropic → openai → gemini)
LLM_PROVIDER=auto

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-TU_CLAVE_API_AQUI
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EXTRACT_MODEL=gpt-4o-mini
OPENAI_SCENARIO_MODEL=gpt-4o

# Anthropic Claude - https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SCENARIO_MODEL=claude-sonnet-4-20250514

# Google Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_EXTRACT_MODEL=gemini-2.0-flash
GEMINI_SCENARIO_MODEL=gemini-2.0-flash

# OSINT Tools (optional - if installed in PATH)
SHERLOCK_PATH=sherlock
RECONNG_PATH=recon-ng
THEHARVESTER_PATH=theHarvester

# External APIs (opcionales - necesarias para enriquecer fuentes específicas)
# NEWS_API_KEY: opcional — sense clau, google_news usa Google News RSS (gratuït)
NEWS_API_KEY=
GITHUB_TOKEN=your-github-token
SHODAN_API_KEY=your-shodan-api-key

# Tavily — cerca web OSINT (https://tavily.com → API Keys)
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAP_EXTRACT_MAX_URLS=8
TAVILY_SEARCH_EXTRACT_MAX_URLS=5
TAVILY_PREFERRED_CRAWL_LIMIT=25
TAVILY_RESEARCH_MAX_WAIT_SECONDS=300
TAVILY_AUTO_EXTRACT_EVENTS=true

# Filtratge d'extracció per temàtica del cas (0..1)
CASE_ARTICLE_RELEVANCE_MIN_SCORE=0.28
CASE_STATEMENT_RELEVANCE_MIN_SCORE=0.22

# Financial APIs (opcionales - para recomendaciones de inversión y métricas financieras)
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (Free: 5 calls/min, 500/day)
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key
# Finnhub: https://finnhub.io/register (Free: 60 calls/min)
FINNHUB_API_KEY=your-finnhub-api-key
# Financial Modeling Prep: https://site.financialmodelingprep.com/developer/docs (Free tier available)
FINANCIAL_MODELING_PREP_API_KEY=your-fmp-api-key

# Geopolitical APIs (opcionales - premium/trial requerido para datasets geopolíticos)
# Permutable AI: https://permutable.ai/datasets-geopolitical-data/ (Requires trial/premium account)
# Contact: enquiries@permutable.ai for free trial
PERMUTABLE_API_KEY=your-permutable-api-key

# Currency Exchange APIs (opcionales - para tipos de cambio)
# ExchangeRate-API: https://www.exchangerate-api.com/ (Free: 1,500 requests/month)
EXCHANGERATE_API_KEY=your-exchangerate-api-key
# Fixer.io: https://fixer.io/ (Free: 100 requests/month)
FIXER_API_KEY=your-fixer-api-key

# Cryptocurrency APIs (opcionales - para datos cripto)
# CoinGecko: https://www.coingecko.com/en/api (Free tier: 10-50 calls/min, no API key required si usas endpoints públicos)
COINGECKO_API_KEY=your-coingecko-api-key

# IP Geolocation APIs (opcionales - para geolocalización por IP)
# ipstack: https://ipstack.com/ (Free: 10,000 requests/month)
IPSTACK_API_KEY=your-ipstack-api-key

# EnsembleData API (opcional - Social Media Scraping)
# Documentation: https://ensembledata.com/apis/docs
# Sign up: https://ensembledata.com/ (Free tier: 50 units/day)
# Supports: TikTok, Instagram, YouTube, Threads, Reddit, Twitter/X, Twitch, Snapchat
ENSEMBLEDATA_API_KEY=your-ensembledata-api-key

# Maltego Transform Server (optional)
MALTEGO_API_URL=https://your-maltego-transform-server.example/api
MALTEGO_API_KEY=your-maltego-api-key

# Article enrichment (extracció OSINT)
ARTICLE_FETCHER_RATE_LIMIT_SEC=1.5
ARTICLE_FETCHER_TIMEOUT_SEC=25
OSINT_POST_ENRICH_MAX_ITEMS=5
GEOPOLITICS_PREFERRED_DOMAINS=foreignaffairs.com,reuters.com,csis.org,nikkei.com,bloomberg.com

# Q2FS parse trigger (hybrid LLM + rule-based fallback)
Q2FS_PARSE_USE_LLM=true
Q2FS_PARSE_CONFIDENCE_THRESHOLD=0.75
Q2FS_PARSE_MAX_TOKENS=800
Q2FS_PARSE_TIMEOUT_SECONDS=8.0

# Q2FS step cache: memory | redis
# memory (default) | redis — per producció amb cache distribuïda:
#   docker compose -f docker-compose.yml -f docker-compose.full.yml --profile full up --build
Q2FS_STEP_CACHE_BACKEND=memory
REDIS_URL=redis://127.0.0.1:6379/0

# Observability
# Stack complet (Redis + Prometheus + Grafana + Jaeger + backend amb traces):
#   docker compose -f docker-compose.yml -f docker-compose.full.yml --profile full up --build
# Només observabilitat sense override Redis/OTEL al backend:
#   docker compose --profile observability up
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER_RATE=1.0
OTEL_SERVICE_NAME=eina-q2fs
STRUCTURED_LOGGING=true
