# Application
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./osint_platform.db

# Security
SECRET_KEY=your-secret-key-change-in-production-use-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI (REQUERIDA para análisis de IA y embeddings)
OPENAI_API_KEY=sk-proj-TU_CLAVE_API_AQUI
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OSINT Tools (optional - if installed in PATH)
SHERLOCK_PATH=sherlock
RECONNG_PATH=recon-ng

# External APIs (opcionales - necesarias para enriquecer fuentes específicas)
NEWS_API_KEY=your-news-api-key
GITHUB_TOKEN=your-github-token
SHODAN_API_KEY=your-shodan-api-key

# Financial APIs (opcionales - para recomendaciones de inversión y métricas financieras)
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (Free: 5 calls/min, 500/day)
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key
# Finnhub: https://finnhub.io/register (Free: 60 calls/min)
FINNHUB_API_KEY=your-finnhub-api-key
# Financial Modeling Prep: https://site.financialmodelingprep.com/developer/docs (Free tier available)
FINANCIAL_MODELING_PREP_API_KEY=your-fmp-api-key

# Geopolitical APIs (opcionales - premium/trial requerido para datasets geopolíticos)
# Permutable AI: https://permutable.ai/datasets-geopolitical-data/ (Requires trial/premium account)
# Contact: enquiries@permutable.ai for free trial
PERMUTABLE_API_KEY=your-permutable-api-key

# Currency Exchange APIs (opcionales - para tipos de cambio)
# ExchangeRate-API: https://www.exchangerate-api.com/ (Free: 1,500 requests/month)
EXCHANGERATE_API_KEY=your-exchangerate-api-key
# Fixer.io: https://fixer.io/ (Free: 100 requests/month)
FIXER_API_KEY=your-fixer-api-key

# Cryptocurrency APIs (opcionales - para datos cripto)
# CoinGecko: https://www.coingecko.com/en/api (Free tier: 10-50 calls/min, no API key required si usas endpoints públicos)
COINGECKO_API_KEY=your-coingecko-api-key

# IP Geolocation APIs (opcionales - para geolocalización por IP)
# ipstack: https://ipstack.com/ (Free: 10,000 requests/month)
IPSTACK_API_KEY=your-ipstack-api-key

# EnsembleData API (opcional - Social Media Scraping)
# Documentation: https://ensembledata.com/apis/docs
# Sign up: https://ensembledata.com/ (Free tier: 50 units/day)
# Supports: TikTok, Instagram, YouTube, Threads, Reddit, Twitter/X, Twitch, Snapchat
ENSEMBLEDATA_API_KEY=your-ensembledata-api-key
